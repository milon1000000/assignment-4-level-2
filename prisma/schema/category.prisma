model Category {
  id          String      @id @default(uuid())
  name        String      @unique @db.VarChar(255)
  description String?

  // Relations
  gearItems   GearItem[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("categories")
}



