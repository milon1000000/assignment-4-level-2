model Review {
  id           String      @id @default(uuid())

  customerId   String
  gearItemId   String

  rating       Int
  comment      String?

  // Relations
  customer     User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  gearItem     GearItem    @relation(fields: [gearItemId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([customerId, gearItemId])
  @@map("reviews")
}


// POST	/api/reviews	Customer
// GET	/api/reviews/gear/:gearId	Public
// GET	/api/reviews/my	Customer
// PATCH	/api/reviews/:reviewId	Customer
// DELETE	/api/reviews/:reviewId	Customer/Admin